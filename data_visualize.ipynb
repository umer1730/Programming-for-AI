   "source": [
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "x = np.linspace(0,4*np.pi,200)\n",
    "y_sin = np.sin(x)\n",
    "plt.plot(x, y_sin, \"b-\",label = \"sin\")\n",
    "plt.scatter(x[::10],y_sin[::10],color = \"red\",label=\"cos\")\n",
    "plt.legend()"
   ]
